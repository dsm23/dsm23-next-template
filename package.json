    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check-types": "next typegen && ./node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest",
    "e2e:headless": "playwright test",
    "e2e:ui": "playwright test --ui",
    "coupling-graph": "pnpm dlx madge --extensions js,jsx,ts,tsx,css,md,mdx ./ --exclude '.next|tailwind.config.js|reset.d.ts|prettier.config.js|postcss.config.js|playwright.config.ts|next.config.js|next-env.d.ts|instrumentation.ts|e2e/|README.md|.storybook/|.eslintrc.js' --image graph.svg"
